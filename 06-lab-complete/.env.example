# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate limiting — 10 req/min per user
RATE_LIMIT_PER_MINUTE=10

# Budget — $10/month per user (stored in Redis)
MONTHLY_BUDGET_USD=10.0

# Storage — Redis for stateless design (conversation history, rate limits, cost)
REDIS_URL=redis://localhost:6379/0

# Conversation history
MAX_HISTORY_MESSAGES=20
HISTORY_TTL_SECONDS=86400

# CORS
ALLOWED_ORIGINS=http://localhost:3000
